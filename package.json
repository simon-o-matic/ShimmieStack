        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.7.0",
        "@types/pg": "^8.20.0",
        "@types/pg-format": "^1.0.5",
        "dotenv": "^17.4.2",
        "tsc-watch": "^7.2.0",
        "typescript": "^6.0.3"
    }
