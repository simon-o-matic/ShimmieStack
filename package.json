    "license": "MIT",
    "dependencies": {
        "@types/jest": "^30.0.0",
        "@types/supertest": "^7.2.0",
        "async-lock": "^1.4.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "ioredis": "^5.10.1",
        "jest": "^30.4.2",
        "pg": "^8.20.0",
        "pg-format": "^1.0.4",
        "pg-query-stream": "^4.14.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "uuid": "^11.1.1"
    },
    "devDependencies": {
        "@types/async-lock": "^1.4.2",
        "@types/body-parser": "^1.19.6",
